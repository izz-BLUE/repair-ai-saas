<!-- 提交报修页 -->
<view class="page-container page-container--with-bottom">
  <!-- 提交成功 -->
  <view wx:if="{{submitted}}" class="state-center" style="padding-top: 100rpx;">
    <view class="state-icon" style="opacity: 1;">✅</view>
    <view class="state-text" style="font-weight: 600; color: var(--color-text);">报修提交成功</view>
    <view class="state-text" style="margin-bottom: 8rpx;">您的工单号</view>
    <view class="ticket-no-box">{{ticketNo}}</view>
    <view class="state-text">请保存工单号，用于后续查询进度</view>
    <button class="btn-primary" style="margin-top: 32rpx; width: 320rpx;" bindtap="goQuery">
      查询进度
    </button>
    <button class="btn-secondary" style="margin-top: 16rpx; width: 320rpx;" bindtap="resetForm">
      返回首页
    </button>
  </view>

  <!-- 表单 -->
  <view wx:else>
    <view class="form-header">
      <view class="form-header-title">提交报修申请</view>
      <view class="form-header-desc">填写以下信息，我们会尽快安排维修师傅处理</view>
    </view>

    <!-- 产品类型 — 标签选择 -->
    <view class="form-group">
      <view class="form-label form-label--required">产品类型</view>
      <view class="product-type-group">
        <view
          wx:for="{{productTypes}}"
          wx:key="value"
          class="product-type-tag {{form.productType === item.value ? 'product-type-tag--active' : ''}}"
          style="{{form.productType === item.value ? 'border-color:' + themeColor + '; background:' + themeColor + '10; color:' + themeColor + ';' : ''}}"
          data-value="{{item.value}}"
          bindtap="onProductTypeTap"
        >
          {{item.label}}
        </view>
      </view>
      <view wx:if="{{errors.productType}}" class="form-error">{{errors.productType}}</view>
    </view>

    <!-- 联系人 -->
    <view class="form-group">
      <view class="form-label form-label--required">联系人</view>
      <input
        class="form-input"
        value="{{form.name}}"
        placeholder="请输入您的姓名"
        bindinput="handleInput"
        data-field="name"
      />
      <view wx:if="{{errors.name}}" class="form-error">{{errors.name}}</view>
    </view>

    <!-- 手机号 -->
    <view class="form-group">
      <view class="form-label form-label--required">手机号</view>
      <input
        class="form-input"
        type="number"
        maxlength="11"
        value="{{form.phone}}"
        placeholder="请输入您的手机号码"
        bindinput="handleInput"
        data-field="phone"
      />
      <view wx:if="{{errors.phone}}" class="form-error">{{errors.phone}}</view>
    </view>

    <!-- 服务地址 -->
    <view class="form-group">
      <view class="form-label form-label--required">服务地址</view>
      <input
        class="form-input"
        value="{{form.address}}"
        placeholder="请输入详细服务地址"
        bindinput="handleInput"
        data-field="address"
      />
      <view wx:if="{{errors.address}}" class="form-error">{{errors.address}}</view>
    </view>

    <!-- 故障描述 -->
    <view class="form-group">
      <view class="form-label form-label--required">故障描述</view>
      <textarea
        class="form-textarea"
        value="{{form.faultDescription}}"
        placeholder="请详细描述设备故障现象（如：空调开机不制冷，显示 E2 错误）"
        bindinput="handleInput"
        data-field="faultDescription"
        maxlength="500"
      />
      <view class="char-count">{{form.faultDescription.length}}/500</view>
      <view wx:if="{{errors.faultDescription}}" class="form-error">{{errors.faultDescription}}</view>
    </view>
  </view>

  <!-- 底部提交按钮 -->
  <view wx:if="{{!submitted}}" class="fixed-bottom">
    <button
      class="btn-primary"
      style="background: {{themeColor}};"
      bindtap="submitRepair"
      loading="{{submitting}}"
      disabled="{{submitting}}"
    >
      {{submitting ? '提交中...' : '提交报修'}}
    </button>
  </view>
</view>
