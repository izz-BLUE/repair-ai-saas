/* 提交报修页 */

.form-header {
  margin-bottom: var(--spacing-lg);
}

.form-header-title {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.form-header-desc {
  font-size: 24rpx;
  color: var(--color-text-hint);
}

.form-group {
  margin-bottom: var(--spacing-md);
}

/* 产品类型标签选择 */
.product-type-group {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.product-type-tag {
  padding: 18rpx 28rpx;
  border-radius: var(--radius-sm);
  font-size: var(--font-body);
  border: 2rpx solid var(--color-border);
  background: #fff;
  color: var(--color-text-secondary);
  transition: all 0.15s;
  line-height: 1;
}

.product-type-tag:active {
  transform: scale(0.96);
}

.product-type-tag--active {
  border-color: var(--color-primary);
  background: var(--color-primary-light);
  color: var(--color-primary);
  font-weight: 500;
}

/* 字数统计 */
.char-count {
  text-align: right;
  font-size: 22rpx;
  color: var(--color-text-hint);
  margin-top: 4rpx;
}

/* 成功页工单号 */
.ticket-no-box {
  font-size: 40rpx;
  font-weight: 700;
  font-family: 'Courier New', monospace;
  letter-spacing: 2rpx;
  color: var(--color-primary);
  padding: 8rpx 32rpx;
  background: var(--color-primary-light);
  border-radius: var(--radius-sm);
  margin-bottom: 16rpx;
}
