# ============================================
# repair-ai-saas 环境变量配置
# 复制为 .env 后修改实际值: cp .env.example .env
# ============================================

# ===== MySQL =====
MYSQL_ROOT_PASSWORD=root          # ⚠️ 生产必须替换
MYSQL_DATABASE=repair_ai_saas

# ===== Redis =====
REDIS_HOST=redis
REDIS_PORT=6379

# ===== Qdrant =====
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# ===== 部署配置 =====
DOMAIN_NAME=localhost             # 生产环境替换为实际域名
FRONTEND_PORT=80                  # 前端/Nginx 端口
BACKEND_PORT=8080                 # Java 后端端口
AGENT_PORT=8090                   # Python Agent 端口

# ===== 数据目录 =====
UPLOADS_DIR=./data/uploads        # 上传文件存储目录
BACKUP_DIR=./backups              # 备份文件存储目录

# ===== 安全配置 =====
# ⚠️ JWT_SECRET 生产必须替换为随机 Base64 密钥！
# 生成方法: openssl rand -base64 32
JWT_SECRET=dGVzdC1zZWNyZXQta2V5LWZvci1yZXBhaXItYWktc2Fhcy12MDEtZGV2ZWxvcG1lbnQ=

# ===== Java 后端 =====
AI_SERVICE_URL=http://agent-python:8090

# ===== Python Agent =====
# ⚠️ 以下 API Key 生产必须配置真实值，否则 AI 服务降级为 SQL LIKE 兜底
LLM_API_KEY=sk-xxx
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
EMBEDDING_API_KEY=sk-xxx
EMBEDDING_MODEL=text-embedding-3-small
